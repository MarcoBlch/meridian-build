---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Projects"
  description="Digital products built by Meridian Build, from AI wardrobe management to escrow messaging."
  wide
>
  <section class="hero">
    <span class="hero-label">Portfolio</span>
    <h1>Projects</h1>
    <p class="hero-intro">
      Everything I'm building, have built, or am planning to build.
      Each project solves a specific problem for a specific audience.
    </p>
  </section>

  <div class="projects-grid">
    {sortedProjects.map(project => (
      <ProjectCard
        name={project.data.name}
        tagline={project.data.tagline}
        status={project.data.status}
        stack={project.data.stack}
        slug={project.id.replace(/\.md$/, '')}
      />
    ))}
  </div>
</BaseLayout>
