---
interface Props {
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  readingTime: number;
}

const { pubDate, updatedDate, tags, readingTime } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdateDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<div class="post-meta">
  <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
  {updatedDate && (
    <span class="post-meta-updated">
      (Updated <time datetime={updatedDate.toISOString()}>{formattedUpdateDate}</time>)
    </span>
  )}
  <span class="post-meta-separator">&middot;</span>
  <span>{readingTime} min read</span>
  <div class="post-meta-tags">
    {tags.map(tag => (
      <a href={`/blog/tags/${tag}`} class="tag">{tag}</a>
    ))}
  </div>
</div>
